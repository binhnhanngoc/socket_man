{
  "name": "socket-man",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SocketMan — Tauri 2 + Rust WebSocket/HTTP workbench",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && node scripts/assert-csp.mjs && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "check:csp": "node scripts/assert-csp.mjs",
    "e2e": "node e2e/run-e2e.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource/instrument-serif": "5.2.8",
    "@tanstack/react-virtual": "^3.14.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "fast-xml-parser": "^4.5.6",
    "js-yaml": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "vite": "6.0.3",
    "vitest": "2.1.8",
    "ws": "^8.21.0"
  }
