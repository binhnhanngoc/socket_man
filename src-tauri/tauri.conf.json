{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SocketMan",
  "version": "0.1.0",
  "identifier": "com.socketman.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SocketMan",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "SocketMan",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 SocketMan",
    "shortDescription": "WebSocket + HTTP workbench",
    "longDescription": "SocketMan is a desktop WebSocket and HTTP workbench: live WS sessions with custom upgrade headers, a real HTTP client, JSON persistence, and OS-keychain secrets.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
